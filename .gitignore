# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
# Build artifacts — the bundle folder + zip belong on Drive/dist/,
# never in git (a 130+ MB zip blew past GitHub's 100 MB file cap).
EXE/
*.zip
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtualenvs / conda
.venv/
venv/
env/
.conda/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini

# App
logs/
*.log
build_log.txt

# Site config — per-studio / per-machine, not project-wide. The
# documented schema lives in flick.toml.example which IS committed;
# a real flick.toml at the repo root is deployment-specific (your
# studio's defaults, a personal dev override) and shouldn't be
# shared via git.
/flick.toml

# Heavy test fixtures (to be discussed case by case)
tests/fixtures/large/

# Claude Code local config — per-developer install, not project-wide.
# Skills installed via `npx claude-code-templates@latest` go under
# .claude/skills/ — re-runnable on any clone, no need to commit them.
.claude/

# Codex / agent workspace cache (skills, transcripts). Same rationale
# as ``.claude/`` — the AGENTS.md notes ARE versioned (project doc),
# the per-machine cache is not.
.agents/

# Graphify knowledge-graph output (generated via /graphify).
# We DO commit the user-facing artifacts (graph.html, graph.json,
# GRAPH_REPORT.md, manifest.json, cost.json, labels) so a fresh
# clone has the architecture map ready without re-running graphify.
# We exclude the internal extraction cache + machine-local interpreter
# paths — those have no value across machines.
graphify-out/cache/
graphify-out/.graphify_python
graphify-out/.graphify_root
graphify-out/.graphify_detect.json
graphify-out/.graphify_extract.json
graphify-out/.graphify_ast.json
graphify-out/.graphify_semantic.json
graphify-out/.graphify_analysis.json
graphify-out/.graphify_chunk_*.json
