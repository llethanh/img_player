# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
# Build artifacts — the bundle folder + zip belong on Drive/dist/,
# never in git (a 130+ MB zip blew past GitHub's 100 MB file cap).
EXE/
*.zip
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtualenvs / conda
.venv/
venv/
env/
.conda/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini

# App
logs/
*.log

# Site config — per-studio / per-machine, not project-wide. The
# documented schema lives in flick.toml.example which IS committed;
# a real flick.toml at the repo root is deployment-specific (your
# studio's defaults, a personal dev override) and shouldn't be
# shared via git.
/flick.toml

# Heavy test fixtures (to be discussed case by case)
tests/fixtures/large/

# Claude Code local config — per-developer install, not project-wide.
# Skills installed via `npx claude-code-templates@latest` go under
# .claude/skills/ — re-runnable on any clone, no need to commit them.
.claude/
